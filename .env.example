# App (URLs vues par le navigateur — garder localhost:3000 en dev Docker)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-to-a-long-random-string

# Database (noms de service Docker Compose)
DATABASE_URL="postgresql://qualiopi:qualiopi@postgres:5432/qualiopi?schema=public"

# Conversion PDF (service gotenberg sur le réseau Docker)
GOTENBERG_URL=http://gotenberg:3000

# Admin (Credentials auth)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme
OPERATEUR_EMAIL=operateur@example.com
OPERATEUR_PASSWORD=changeme

# Email — resend (default) or smtp
MAIL_PROVIDER=resend
MAIL_FROM=onboarding@resend.dev
MAIL_FROM_NAME=Agence Charlie
RESEND_API_KEY=re_xxxxxxxx

# SMTP (Brevo etc.) when MAIL_PROVIDER=smtp
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Resend sans domaine vérifié : email du compte Resend uniquement
MAIL_TEST_TO=votre@gmail.com
# POC : redirige tous les envois vers cette adresse (évite l'erreur Resend)
MAIL_DEV_REDIRECT=votre@gmail.com

# Cron
CRON_SECRET=change-me-cron-secret

# Object storage
# local = filesystem under storage/ (default, dev rapide)
# r2    = API S3 (Cloudflare R2 prod, ou MinIO local via Docker)
STORAGE_DRIVER=local

# --- MinIO (dev Docker) — tester le même driver S3 qu'en prod ---
# Copier ces lignes dans .env puis : ./scripts/smoke-storage-minio.sh
# Console MinIO : http://localhost:9001 (minioadmin / minioadmin)
# STORAGE_DRIVER=r2
# R2_ENDPOINT=http://minio:9000
# R2_BUCKET=qualiopi-dev
# R2_ACCESS_KEY_ID=minioadmin
# R2_SECRET_ACCESS_KEY=minioadmin
# R2_S3_FORCE_PATH_STYLE=true

# --- Cloudflare R2 (production) ---
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
# R2_ENDPOINT=https://<account>.r2.cloudflarestorage.com
