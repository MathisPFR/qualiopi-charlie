# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-to-a-long-random-string

# Database
DATABASE_URL="postgresql://qualiopi:qualiopi@localhost:5432/qualiopi?schema=public"

# Conversion PDF (Gotenberg / LibreOffice dans Docker)
GOTENBERG_URL=http://localhost:3001

# Admin (Credentials auth)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme

# Email — resend (default) or smtp
MAIL_PROVIDER=resend
MAIL_FROM=onboarding@resend.dev
MAIL_FROM_NAME=Agence Charlie
RESEND_API_KEY=re_xxxxxxxx

# SMTP (Brevo etc.) when MAIL_PROVIDER=smtp
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Resend sans domaine vérifié : email du compte Resend uniquement
MAIL_TEST_TO=votre@gmail.com
# POC : redirige tous les envois vers cette adresse (évite l'erreur Resend)
MAIL_DEV_REDIRECT=votre@gmail.com

# Cron
CRON_SECRET=change-me-cron-secret
